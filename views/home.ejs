<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>My Drive</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    :root{--pink:#f8dfe0;--card:#2f3a44;--muted:#cfd8dc;}
    html,body{height:100%}
    body{
      margin:0;
      min-height:100%;
      background:var(--pink);
      font-family:Inter,system-ui,Segoe UI,Roboto,"Helvetica Neue",Arial;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:24px;
    }

    .drive-wrapper{
      width: 920px;
      max-width:95%;
      display:block;
    }

    .drop-area {
      height: 260px;
      background: var(--card);
      border-radius: 10px;
      display:flex;
      align-items:center;
      justify-content:center;
      color:var(--muted);
      text-align:center;
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
      margin: 0 auto 28px auto;
      padding: 20px;
      cursor:pointer;
    }
    .drop-area .icon{ font-size:34px;margin-bottom:8px; }
    .drop-area .title{ font-weight:600;margin-bottom:6px;color:#e6eef2; }
    .drop-area .subtitle{ font-size:13px;color:#aebcc1; }

    .file-list {
      background: rgba(255,255,255,0.4);
      border-radius: 12px;
      padding: 14px;
      display:flex;
      flex-direction:column;
      gap:10px;
    }
    .file-row{
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding:10px;
      border-radius:8px;
      background:rgba(255,255,255,0.9);
      box-shadow: 0 2px 8px rgba(0,0,0,0.04);
    }
    .file-left{ display:flex;align-items:center;gap:12px }
    .thumb{
      width:72px;height:56px;border-radius:8px;object-fit:cover;
      background:#f1f3f4;display:inline-block;
    }
    .file-meta{line-height:1}
    .file-name{font-weight:600}
    .file-url{font-size:12px;color:#6b7280}

    /* ---------- CLOUD POPUP ---------- */
    .popup {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 999;
    }
    .popup-box {
      width: 350px;
      margin: 10% auto;
      background: white;
      padding: 20px;
      border-radius: 12px;
      text-align: center;
      animation: fadeIn .2s;
    }
    @keyframes fadeIn {
      from { transform: scale(0.8); opacity:0; }
      to { transform: scale(1); opacity:1; }
    }
    .cloud-select {
      display:block;
      padding:20px;
      border:2px dashed #4a90e2;
      border-radius:10px;
      cursor:pointer;
      margin-top:15px;
      color:#4a90e2;
      font-weight:600;
    }
    .cloud-select:hover { background:#eaf2ff; }
    .close-btn { float:right;cursor:pointer;font-size:20px; }
  </style>
</head>

<body>
  <div class="drive-wrapper">

    <!-- Drop Area -->
    <div class="drop-area" id="dropArea" onclick="openCloudPopup()">
      <div>
        <div class="icon">☁️</div>
        <div class="title">Click to upload or drag and drop</div>
        <div class="subtitle">SVG, PNG, JPG or GIF (MAX. 800x400px)</div>
      </div>
    </div>

    <!-- Hidden Form -->
    <form id="uploadForm" action="/index/upload" method="POST" enctype="multipart/form-data" style="display:none">
      <input id="fileInput" type="file" name="myfile" />
    </form>

    <!-- File List -->
    <div class="file-list mt-3">
      <%
        const fallback = { name: 'Screenshot (135).png', url: '/mnt/data/Screenshot (135).png', type: 'image' };
        const renderFiles = (files && files.length) ? files : [fallback];
      %>

      <% renderFiles.forEach(f => { %>
        <div class="file-row">
          <div class="file-left">
            <% if (f.type?.startsWith('image') || /\.(png|jpe?g|gif|svg)$/i.test(f.url)) { %>
              <img src="<%= f.url %>" class="thumb" alt="<%= f.name %>">
            <% } else { %>
              <div class="thumb" style="display:flex;align-items:center;justify-content:center">📄</div>
            <% } %>

            <div class="file-meta">
              <div class="file-name"><%= f.name %></div>
              <div class="file-url"><%= f.url %></div>
            </div>
          </div>

          <a class="btn btn-sm btn-outline-primary" href="<%= f.url %>" download>Download</a>
        </div>
      <% }) %>
    </div>

  </div>

  <!-- CLOUD POPUP -->
  <div id="cloudPopup" class="popup">
    <div class="popup-box">
      <span class="close-btn">&times;</span>
      <h3>Select a file to upload</h3>

      <label for="popupFile" class="cloud-select">☁️ Choose from device</label>
      <input type="file" id="popupFile" hidden />
    </div>
  </div>

  <script>
    function openCloudPopup() {
      document.getElementById('cloudPopup').style.display = "block";
    }

    document.querySelector(".close-btn").onclick = function(){
      document.getElementById('cloudPopup').style.display = "none";
    };

    window.onclick = function(e){
      if(e.target == document.getElementById('cloudPopup')){
        document.getElementById('cloudPopup').style.display = "none";
      }
    };

    document.getElementById("popupFile").addEventListener("change", function(){
      const realInput = document.getElementById("fileInput");
      const dt = new DataTransfer();
      dt.items.add(this.files[0]);
      realInput.files = dt.files;
      document.getElementById("uploadForm").submit();
    });

    // drag drop
    const dropArea = document.getElementById("dropArea");
    ["dragenter","dragover"].forEach(ev =>
      dropArea.addEventListener(ev, e => { e.preventDefault(); dropArea.style.opacity=0.9; })
    );
    ["dragleave","drop"].forEach(ev =>
      dropArea.addEventListener(ev, e => { e.preventDefault(); dropArea.style.opacity=1; })
    );
    dropArea.addEventListener("drop", e => {
      const file = e.dataTransfer.files[0];
      const realInput = document.getElementById("fileInput");
      const dt = new DataTransfer();
      dt.items.add(file);
      realInput.files = dt.files;
      document.getElementById("uploadForm").submit();
    });
  </script>
</body>
</html>
